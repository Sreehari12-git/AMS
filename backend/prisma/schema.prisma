generator client {
 provider = "prisma-client-js" 
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  full_name String
  password String
  role String
  fcmToken  String?
  created_at DateTime @default(now())

  attendance Attendance[]
  leaves Leave[]
  leaveBalance LeaveBalance?
} 

model Attendance { 
  id        Int     @id @default(autoincrement()) 
  userId Int
  date DateTime
  day String?
  clockIn DateTime?
  clockOut DateTime?
  duration String?
  leaveType String?
  totalHours Float?
  latitude Decimal?
  longitude Decimal?
  status String @default("ABSENT")
  created_at DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
  @@unique([userId,date])
} 

model Leave {
  id Int @id @default(autoincrement())
  userId Int 
  type String
  status String
  startDate DateTime
  endDate DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id])
}

model LeaveBalance {
  id Int @id @default(autoincrement())
  userId Int @unique

  annualTotal Int @default(15)
  annualUsed Int @default(0)

  sickTotal Int @default(10)
  sickUsed Int @default(0)

  remoteTotal Int @default(10)
  remoteUsed Int @default(0)

  user User @relation(fields: [userId], references: [id])
}
